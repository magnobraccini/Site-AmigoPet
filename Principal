<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Amigo Pet Agropet – Cuidando com Dedicação e Carinho</title>
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;600;700;800&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,400&display=swap" rel="stylesheet"/>
  <style>
    :root {
      --navy: #1a2e6e;
      --navy-dark: #0f1d4a;
      --navy-light: #2a4090;
      --amber: #f5a623;
      --amber-light: #ffc857;
      --amber-dark: #d4891a;
      --white: #ffffff;
      --off-white: #f8f9fc;
      --gray-light: #edf0f7;
      --gray: #8892aa;
      --text: #1c2340;
      --radius: 16px;
      --radius-sm: 8px;
      --shadow: 0 8px 32px rgba(26,46,110,0.12);
      --shadow-lg: 0 20px 60px rgba(26,46,110,0.18);
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }
    html { scroll-behavior: smooth; }

    body {
      font-family: 'DM Sans', sans-serif;
      color: var(--text);
      background: var(--white);
      overflow-x: hidden;
    }

    h1,h2,h3,h4 { font-family: 'Sora', sans-serif; }

    /* ───── NAVBAR ───── */
    nav {
      position: fixed; top: 0; left: 0; right: 0; z-index: 1000;
      background: rgba(255,255,255,0.92);
      backdrop-filter: blur(16px);
      border-bottom: 1px solid rgba(26,46,110,0.08);
      padding: 0 5%;
      height: 70px;
      display: flex; align-items: center; justify-content: space-between;
      transition: box-shadow .3s;
    }
    nav.scrolled { box-shadow: var(--shadow); }

    .nav-logo { display: flex; align-items: center; gap: 10px; text-decoration: none; }
    .nav-logo-icon {
      width: 44px; height: 44px; border-radius: 50%;
      background: var(--navy);
      display: flex; align-items: center; justify-content: center;
      font-size: 22px;
    }
    .nav-logo-text { font-family: 'Sora', sans-serif; font-weight: 700; font-size: 1.05rem; color: var(--navy); line-height: 1.1; }
    .nav-logo-sub { font-size: .7rem; color: var(--amber-dark); font-weight: 600; letter-spacing: .05em; text-transform: uppercase; }

    .nav-links { display: flex; gap: 2rem; list-style: none; }
    .nav-links a { text-decoration: none; color: var(--text); font-size: .9rem; font-weight: 500; transition: color .2s; position: relative; }
    .nav-links a::after { content:''; position:absolute; bottom:-3px; left:0; width:0; height:2px; background:var(--amber); transition: width .3s; border-radius:2px; }
    .nav-links a:hover { color: var(--navy); }
    .nav-links a:hover::after { width: 100%; }

    .nav-cta {
      background: var(--amber); color: var(--navy-dark); font-family: 'Sora', sans-serif;
      font-weight: 700; font-size: .85rem; padding: 10px 22px; border-radius: 50px;
      text-decoration: none; transition: transform .2s, box-shadow .2s;
      box-shadow: 0 4px 16px rgba(245,166,35,.35);
    }
    .nav-cta:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(245,166,35,.45); }

    .hamburger { display: none; flex-direction: column; gap: 5px; cursor: pointer; padding: 4px; }
    .hamburger span { width: 24px; height: 2px; background: var(--navy); border-radius: 2px; transition: .3s; }

    /* ───── HERO ───── */
    #hero {
      min-height: 100vh;
      background: linear-gradient(135deg, var(--navy-dark) 0%, var(--navy) 50%, var(--navy-light) 100%);
      display: flex; align-items: center;
      padding: 90px 5% 60px;
      position: relative; overflow: hidden;
    }

    .hero-bg-shapes { position: absolute; inset: 0; overflow: hidden; pointer-events: none; }
    .hero-bg-shapes::before {
      content:''; position:absolute; width:500px; height:500px; border-radius:50%;
      background: radial-gradient(circle, rgba(245,166,35,.15) 0%, transparent 70%);
      top: -100px; right: -100px;
      animation: pulse 6s ease-in-out infinite;
    }
    .hero-bg-shapes::after {
      content:''; position:absolute; width:300px; height:300px; border-radius:50%;
      background: radial-gradient(circle, rgba(255,255,255,.06) 0%, transparent 70%);
      bottom: 50px; left: 10%;
      animation: pulse 8s ease-in-out infinite reverse;
    }
    @keyframes pulse { 0%,100%{transform:scale(1)} 50%{transform:scale(1.15)} }

    .hero-content { max-width: 1200px; margin: 0 auto; width: 100%; display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: center; position: relative; z-index: 1; }

    .hero-badge {
      display: inline-flex; align-items: center; gap: 8px;
      background: rgba(245,166,35,.2); border: 1px solid rgba(245,166,35,.4);
      color: var(--amber-light); padding: 6px 16px; border-radius: 50px;
      font-size: .8rem; font-weight: 600; letter-spacing: .05em; margin-bottom: 24px;
      animation: fadeUp .6s ease both;
    }
    .hero-badge::before { content: '🐾'; }

    .hero-title {
      font-size: clamp(2.2rem, 4vw, 3.5rem); font-weight: 800;
      color: var(--white); line-height: 1.1; margin-bottom: 20px;
      animation: fadeUp .6s .1s ease both;
    }
    .hero-title span { color: var(--amber); }

    .hero-desc {
      color: rgba(255,255,255,.75); font-size: 1.05rem; line-height: 1.7;
      margin-bottom: 36px; animation: fadeUp .6s .2s ease both;
    }

    .hero-btns { display: flex; gap: 16px; flex-wrap: wrap; animation: fadeUp .6s .3s ease both; }
    .btn-primary {
      background: var(--amber); color: var(--navy-dark);
      padding: 14px 28px; border-radius: 50px; font-family: 'Sora', sans-serif;
      font-weight: 700; font-size: .95rem; text-decoration: none;
      transition: transform .2s, box-shadow .2s;
      box-shadow: 0 6px 24px rgba(245,166,35,.4);
    }
    .btn-primary:hover { transform: translateY(-3px); box-shadow: 0 12px 32px rgba(245,166,35,.5); }
    .btn-secondary {
      background: rgba(255,255,255,.1); color: var(--white); border: 1.5px solid rgba(255,255,255,.3);
      padding: 14px 28px; border-radius: 50px; font-family: 'Sora', sans-serif;
      font-weight: 600; font-size: .95rem; text-decoration: none;
      transition: background .2s, border-color .2s;
    }
    .btn-secondary:hover { background: rgba(255,255,255,.18); border-color: rgba(255,255,255,.6); }

    .hero-stats { display: flex; gap: 32px; margin-top: 40px; animation: fadeUp .6s .4s ease both; }
    .hero-stat { text-align: center; }
    .hero-stat strong { display: block; font-family: 'Sora', sans-serif; font-size: 1.8rem; font-weight: 800; color: var(--amber); }
    .hero-stat span { font-size: .8rem; color: rgba(255,255,255,.6); }

    .hero-card {
      background: rgba(255,255,255,.07); backdrop-filter: blur(12px);
      border: 1px solid rgba(255,255,255,.15); border-radius: 24px;
      padding: 32px; animation: fadeUp .6s .2s ease both;
    }

    .hero-doc-photo {
      width: 100%; border-radius: 16px; object-fit: cover; height: 280px;
      border: 3px solid rgba(245,166,35,.4);
    }
    .hero-doc-info {
      margin-top: 20px; padding-top: 20px;
      border-top: 1px solid rgba(255,255,255,.1);
      display: flex; align-items: center; gap: 16px;
    }
    .doc-avatar { width: 52px; height: 52px; border-radius: 50%; border: 2px solid var(--amber); overflow: hidden; flex-shrink: 0; }
    .doc-avatar img { width: 100%; height: 100%; object-fit: cover; object-position: center top; }
    .doc-name { font-family: 'Sora', sans-serif; font-weight: 700; color: var(--white); font-size: 1rem; }
    .doc-title { font-size: .8rem; color: var(--amber-light); }
    .doc-badge { margin-left: auto; background: rgba(245,166,35,.2); border: 1px solid var(--amber); border-radius: 6px; padding: 4px 10px; font-size: .7rem; color: var(--amber-light); font-weight: 600; }

    .hero-features { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-top: 16px; }
    .hero-feature {
      display: flex; align-items: center; gap: 8px;
      color: rgba(255,255,255,.8); font-size: .82rem;
    }
    .hero-feature::before { content: '✓'; color: var(--amber); font-weight: 700; font-size: .9rem; }

    @keyframes fadeUp { from{opacity:0;transform:translateY(20px)} to{opacity:1;transform:translateY(0)} }

    /* ───── SECTION COMMONS ───── */
    section { padding: 80px 5%; }
    .section-label {
      display: inline-flex; align-items: center; gap: 6px;
      background: rgba(26,46,110,.06); color: var(--navy);
      padding: 5px 14px; border-radius: 50px; font-size: .75rem;
      font-weight: 700; letter-spacing: .08em; text-transform: uppercase; margin-bottom: 14px;
    }
    .section-title { font-size: clamp(1.8rem, 3vw, 2.6rem); font-weight: 800; color: var(--navy-dark); line-height: 1.2; margin-bottom: 16px; }
    .section-title span { color: var(--amber-dark); }
    .section-desc { color: var(--gray); font-size: 1rem; line-height: 1.7; max-width: 520px; }
    .section-header { margin-bottom: 50px; }
    .center { text-align: center; }
    .center .section-desc { margin: 0 auto; }

    .container { max-width: 1200px; margin: 0 auto; }

    /* ───── SERVICES ───── */
    #servicos { background: var(--off-white); }

    .services-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 24px; }

    .service-card {
      background: var(--white); border-radius: var(--radius); padding: 32px 28px;
      box-shadow: var(--shadow); border: 1px solid rgba(26,46,110,.06);
      transition: transform .3s, box-shadow .3s;
      position: relative; overflow: hidden;
    }
    .service-card::before {
      content:''; position:absolute; top:0; left:0; right:0; height:4px;
      background: linear-gradient(90deg, var(--navy), var(--amber));
      transform: scaleX(0); transform-origin: left; transition: transform .3s;
    }
    .service-card:hover { transform: translateY(-6px); box-shadow: var(--shadow-lg); }
    .service-card:hover::before { transform: scaleX(1); }

    .service-icon {
      width: 56px; height: 56px; border-radius: 14px;
      background: linear-gradient(135deg, var(--navy), var(--navy-light));
      display: flex; align-items: center; justify-content: center;
      font-size: 26px; margin-bottom: 20px;
      box-shadow: 0 6px 20px rgba(26,46,110,.25);
    }
    .service-card h3 { font-size: 1.1rem; font-weight: 700; color: var(--navy-dark); margin-bottom: 10px; }
    .service-card p { color: var(--gray); font-size: .9rem; line-height: 1.6; margin-bottom: 16px; }
    .service-tag { display: inline-block; background: rgba(245,166,35,.12); color: var(--amber-dark); padding: 4px 10px; border-radius: 50px; font-size: .75rem; font-weight: 600; }

    /* ───── DOCTOR ───── */
    #medico { background: var(--white); }

    .doctor-grid { display: grid; grid-template-columns: 1fr 1.4fr; gap: 60px; align-items: center; }

    .doctor-photo-wrap { position: relative; }
    .doctor-photo-bg {
      width: 100%; border-radius: 24px; overflow: hidden;
      box-shadow: var(--shadow-lg);
      aspect-ratio: 3/4;
    }
    .doctor-photo-bg img { width: 100%; height: 100%; object-fit: cover; object-position: center top; }
    .doctor-photo-badge {
      position: absolute; bottom: -16px; right: -16px;
      background: var(--amber); border-radius: 16px; padding: 16px 20px;
      box-shadow: 0 8px 24px rgba(245,166,35,.4); text-align: center;
    }
    .doctor-photo-badge strong { display: block; font-family: 'Sora', sans-serif; font-size: 1.8rem; font-weight: 800; color: var(--navy-dark); }
    .doctor-photo-badge span { font-size: .75rem; color: var(--navy); font-weight: 600; }

    .doctor-qualities { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-top: 32px; }
    .quality-item {
      display: flex; align-items: flex-start; gap: 12px;
      background: var(--off-white); border-radius: var(--radius-sm); padding: 16px;
    }
    .quality-icon { font-size: 1.5rem; flex-shrink: 0; }
    .quality-text h4 { font-size: .9rem; font-weight: 700; color: var(--navy-dark); margin-bottom: 2px; }
    .quality-text p { font-size: .78rem; color: var(--gray); line-height: 1.4; }

    /* ───── CATALOG ───── */
    #catalogo { background: var(--off-white); }

    .catalog-tabs { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 36px; }
    .tab-btn {
      padding: 8px 20px; border-radius: 50px; border: 1.5px solid rgba(26,46,110,.15);
      background: var(--white); color: var(--gray); font-family: 'Sora', sans-serif;
      font-weight: 600; font-size: .85rem; cursor: pointer; transition: .2s;
    }
    .tab-btn.active, .tab-btn:hover { background: var(--navy); border-color: var(--navy); color: var(--white); }

    .catalog-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 20px; }

    .product-card {
      background: var(--white); border-radius: var(--radius); overflow: hidden;
      box-shadow: 0 2px 16px rgba(26,46,110,.08); transition: transform .3s, box-shadow .3s;
    }
    .product-card:hover { transform: translateY(-4px); box-shadow: var(--shadow); }

    .product-img {
      height: 160px; background: linear-gradient(135deg, var(--off-white), var(--gray-light));
      display: flex; align-items: center; justify-content: center; font-size: 56px;
      position: relative;
    }
    .product-badge-new {
      position: absolute; top: 10px; left: 10px;
      background: var(--amber); color: var(--navy-dark); font-size: .65rem;
      font-weight: 700; padding: 3px 8px; border-radius: 50px;
    }
    .product-info { padding: 16px; }
    .product-info h4 { font-size: .92rem; font-weight: 700; color: var(--navy-dark); margin-bottom: 4px; }
    .product-info p { font-size: .8rem; color: var(--gray); margin-bottom: 12px; }
    .product-footer { display: flex; align-items: center; justify-content: space-between; }
    .product-contact-btn {
      background: var(--navy); color: var(--white); border: none;
      padding: 7px 14px; border-radius: 50px; font-size: .78rem; font-weight: 600;
      cursor: pointer; text-decoration: none; transition: background .2s;
    }
    .product-contact-btn:hover { background: var(--navy-light); }
    .delivery-tag { font-size: .72rem; color: var(--amber-dark); font-weight: 600; }

    /* ───── BOOKING ───── */
    #agendamento {
      background: linear-gradient(135deg, var(--navy-dark), var(--navy));
      position: relative; overflow: hidden;
    }
    #agendamento::before {
      content:''; position:absolute; top:-200px; right:-200px;
      width: 500px; height: 500px; border-radius: 50%;
      background: radial-gradient(circle, rgba(245,166,35,.1) 0%, transparent 70%);
    }

    #agendamento .section-title { color: var(--white); }
    #agendamento .section-label { background: rgba(245,166,35,.2); color: var(--amber-light); }
    #agendamento .section-desc { color: rgba(255,255,255,.65); }

    .booking-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: start; position: relative; z-index: 1; }

    .booking-form {
      background: rgba(255,255,255,.08); backdrop-filter: blur(12px);
      border: 1px solid rgba(255,255,255,.15); border-radius: 24px; padding: 36px;
    }
    .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 16px; }
    .form-group { margin-bottom: 16px; }
    .form-group label { display: block; font-size: .82rem; font-weight: 600; color: rgba(255,255,255,.8); margin-bottom: 6px; }
    .form-group input, .form-group select, .form-group textarea {
      width: 100%; padding: 12px 16px; border-radius: var(--radius-sm);
      background: rgba(255,255,255,.1); border: 1.5px solid rgba(255,255,255,.2);
      color: var(--white); font-family: 'DM Sans', sans-serif; font-size: .9rem;
      outline: none; transition: border-color .2s;
    }
    .form-group input::placeholder, .form-group textarea::placeholder { color: rgba(255,255,255,.4); }
    .form-group input:focus, .form-group select:focus, .form-group textarea:focus { border-color: var(--amber); }
    .form-group select option { background: var(--navy-dark); color: var(--white); }
    .form-group textarea { resize: none; height: 90px; }

    .submit-btn {
      width: 100%; padding: 15px; background: var(--amber);
      color: var(--navy-dark); font-family: 'Sora', sans-serif; font-weight: 700;
      font-size: 1rem; border: none; border-radius: 50px; cursor: pointer;
      transition: transform .2s, box-shadow .2s;
      box-shadow: 0 6px 24px rgba(245,166,35,.4);
    }
    .submit-btn:hover { transform: translateY(-2px); box-shadow: 0 12px 32px rgba(245,166,35,.5); }

    .booking-info { padding-top: 8px; }
    .booking-info-item {
      display: flex; gap: 16px; align-items: flex-start;
      background: rgba(255,255,255,.06); border-radius: var(--radius-sm);
      padding: 18px; margin-bottom: 12px; border: 1px solid rgba(255,255,255,.08);
    }
    .booking-info-icon { font-size: 1.4rem; flex-shrink: 0; }
    .booking-info-item h4 { font-size: .9rem; font-weight: 700; color: var(--white); margin-bottom: 2px; }
    .booking-info-item p { font-size: .82rem; color: rgba(255,255,255,.65); line-height: 1.5; }

    /* ───── MAP ───── */
    #localizacao { background: var(--white); }

    .map-grid { display: grid; grid-template-columns: 1fr 1.5fr; gap: 50px; align-items: center; }

    .map-info-item { display: flex; gap: 14px; margin-bottom: 22px; align-items: flex-start; }
    .map-icon {
      width: 44px; height: 44px; background: rgba(26,46,110,.08); border-radius: 10px;
      display: flex; align-items: center; justify-content: center; font-size: 1.2rem; flex-shrink: 0;
    }
    .map-info-item h4 { font-size: .9rem; font-weight: 700; color: var(--navy-dark); margin-bottom: 2px; }
    .map-info-item p { font-size: .85rem; color: var(--gray); line-height: 1.5; }

    .map-frame-wrap { border-radius: 20px; overflow: hidden; box-shadow: var(--shadow-lg); height: 400px; }
    .map-frame-wrap iframe { width: 100%; height: 100%; border: none; }

    /* ───── CONTACT FLOAT ───── */
    .float-btns { position: fixed; bottom: 24px; right: 24px; z-index: 500; display: flex; flex-direction: column; gap: 12px; }
    .float-btn {
      width: 52px; height: 52px; border-radius: 50%; border: none; cursor: pointer;
      display: flex; align-items: center; justify-content: center; font-size: 1.3rem;
      box-shadow: 0 4px 20px rgba(0,0,0,.2); transition: transform .2s;
      text-decoration: none;
    }
    .float-btn:hover { transform: scale(1.1); }
    .float-btn.whatsapp { background: #25d366; color: white; }
    .float-btn.instagram { background: linear-gradient(45deg, #f09433, #e6683c, #dc2743, #cc2366, #bc1888); color: white; }
    .float-btn.phone { background: var(--navy); color: white; display: none; }

    /* ───── FOOTER ───── */
    footer {
      background: var(--navy-dark); color: rgba(255,255,255,.7);
      padding: 60px 5% 30px;
    }
    .footer-grid { max-width: 1200px; margin: 0 auto; display: grid; grid-template-columns: 2fr 1fr 1fr 1.5fr; gap: 40px; margin-bottom: 40px; }
    footer h4 { font-family: 'Sora', sans-serif; color: var(--white); font-size: .95rem; margin-bottom: 16px; }
    footer p, footer a { font-size: .85rem; line-height: 1.8; color: rgba(255,255,255,.6); text-decoration: none; display: block; }
    footer a:hover { color: var(--amber); }
    .footer-bottom { border-top: 1px solid rgba(255,255,255,.1); padding-top: 24px; max-width: 1200px; margin: 0 auto; display: flex; justify-content: space-between; align-items: center; font-size: .8rem; }
    .footer-logo-text { font-family: 'Sora', sans-serif; font-weight: 800; font-size: 1.2rem; color: var(--white); }
    .footer-logo-sub { font-size: .72rem; color: var(--amber); letter-spacing: .1em; text-transform: uppercase; }

    /* ───── HOURS PILL ───── */
    .hours-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
    .hours-item { background: rgba(255,255,255,.05); border-radius: 8px; padding: 10px 14px; }
    .hours-item .day { font-size: .75rem; color: var(--amber-light); font-weight: 700; text-transform: uppercase; letter-spacing: .05em; }
    .hours-item .time { font-size: .82rem; color: rgba(255,255,255,.7); }

    /* ───── TOAST ───── */
    .toast {
      position: fixed; bottom: 100px; right: 24px; z-index: 2000;
      background: var(--white); border-radius: var(--radius-sm); padding: 16px 20px;
      box-shadow: var(--shadow-lg); display: flex; align-items: center; gap: 12px;
      transform: translateX(120%); transition: transform .4s ease; max-width: 320px;
      border-left: 4px solid #25d366;
    }
    .toast.show { transform: translateX(0); }
    .toast-icon { font-size: 1.4rem; }
    .toast h4 { font-size: .9rem; font-weight: 700; color: var(--navy-dark); }
    .toast p { font-size: .78rem; color: var(--gray); }

    /* ───── MOBILE MENU ───── */
    .mobile-nav {
      display: none; position: fixed; top: 70px; left: 0; right: 0; z-index: 999;
      background: var(--white); padding: 20px 5%; box-shadow: var(--shadow);
      flex-direction: column; gap: 16px;
    }
    .mobile-nav.open { display: flex; }
    .mobile-nav a { color: var(--text); text-decoration: none; font-size: 1rem; font-weight: 500; padding: 8px 0; border-bottom: 1px solid var(--gray-light); }

    /* ───── RESPONSIVE ───── */
    @media (max-width: 900px) {
      .hero-content { grid-template-columns: 1fr; gap: 40px; }
      .hero-card { display: none; }
      .doctor-grid { grid-template-columns: 1fr; }
      .booking-grid { grid-template-columns: 1fr; }
      .map-grid { grid-template-columns: 1fr; }
      .footer-grid { grid-template-columns: 1fr 1fr; }
      .form-row { grid-template-columns: 1fr; }
    }

    @media (max-width: 600px) {
      .nav-links, .nav-cta { display: none; }
      .hamburger { display: flex; }
      .footer-grid { grid-template-columns: 1fr; }
      .float-btn.phone { display: flex; }
      .hero-stats { gap: 20px; }
